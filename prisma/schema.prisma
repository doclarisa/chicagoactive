// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Listing {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  description  String

  category     String        // one of lib/categories.ts CATEGORIES[].slug
  neighborhood String?       // e.g. "Naperville", "Museum Campus"
  county       String        // one of lib/counties.ts COUNTIES

  cost         Cost          @default(FREE)
  days         Json?         // string[] e.g. ["Tuesday", "Thursday"]
  time         String?       // free text, e.g. "6:30-9:30 PM"; schedules vary seasonally

  sourceUrl    String?       // where this listing's info was verified
  imageUrl     String?

  address        String?     // full street address, when known
  phone          String?
  hours          String?     // free text, e.g. "Mon-Fri 8:30am-4:30pm"
  ageEligibility String?     // free text, e.g. "55+; no residency required"
  registration   String?     // free text, e.g. "Register online at ahpd.org"
  accessibility  String?     // free text, e.g. "Wheelchair accessible"

  status       ListingStatus @default(PUBLISHED)

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([county])
  @@index([category])
  @@index([status])
}

enum Cost {
  FREE
  LOW_COST
  PAID
}

enum ListingStatus {
  PUBLISHED
  PENDING
}
